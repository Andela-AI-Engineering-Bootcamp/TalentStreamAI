# Copy to "backend.hcl" (gitignored) for remote Terraform state.
# GitHub Actions generates this file during deploys.
#
# First-time setup: provision bucket + lock table with terraform/bootstrap/
# (see terraform/bootstrap/README.md), then fill bucket / region / dynamodb_table here.

bucket         = "your-terraform-state-bucket"
key            = "talentstreamai/dev/terraform.tfstate"
region         = "eu-central-1"
dynamodb_table = "terraform-locks"
encrypt        = true
